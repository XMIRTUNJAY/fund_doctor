# Fund Doctor — Environment Variables
# Copy this file to .env and fill in values as needed.

# Database path (default: ./data/fund_doctor.db)
# DB_PATH=./data/fund_doctor.db

# Optional: Morningstar or ValueResearch API keys (future use)
# MORNINGSTAR_API_KEY=
# VR_API_KEY=

# Risk-free rate for Sharpe/Sortino calculation (default: 0.065 = 6.5%)
# RISK_FREE_RATE=0.065
